# MySQL (defaults suit local XAMPP-style installs if you omit these in development)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=green_valley

# Run CREATE TABLE / procedures on startup (set false when DB is managed elsewhere)
# DB_AUTO_SYNC=true

# HTTP server (frontend expects this port in development unless you change Vite/API URLs)
PORT=5000

# Allowed browser origin for CORS (required when NODE_ENV=production)
# CORS_ORIGIN=http://localhost:8080

# Set to production in real deployments (enforces DB_USER, DB_NAME, CORS_ORIGIN, JWT_SECRET)
# NODE_ENV=production
#
# In development (NODE_ENV not production), sample data is applied if missing:
#   admin user: admin / admin
#   rooms, menu_items, banquet_packages (empty tables get demo rows; banquet uses INSERT...WHERE NOT EXISTS)
# This does not run in production.

# JWT (JWT_SECRET required in production)
# JWT_SECRET=use-a-long-random-string
# JWT_EXPIRES_IN=7d

# Nodemailer (Gmail app password or SMTP)
EMAIL_USER=dilumgihana@gmail.com
EMAIL_PASS=rsahxbgxwgzaejum

# Shown in confirmation emails for guest inquiries (falls back to EMAIL_USER if unset)
# RESORT_PUBLIC_EMAIL=greenvalleyresortk@gmail.com
